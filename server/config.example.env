# Numbl Execution Service Configuration

# Port for the service to listen on
NUMBL_SERVICE_PORT=3001

# Maximum number of concurrent script executions
NUMBL_MAX_CONCURRENT=3

# Timeout for script execution in milliseconds (default: 30000 = 30 seconds)
NUMBL_TIMEOUT_MS=30000

# Maximum memory per execution in MB (default: 1024 = 1 GB)
NUMBL_MAX_MEMORY_MB=1024

# Secret token for the /update endpoint (leave blank to disable the endpoint)
# Generate with: openssl rand -hex 32
NUMBL_UPDATE_SECRET=
