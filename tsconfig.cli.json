{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "outDir": "./dist-cli",
    "rootDir": "./src",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "noEmit": false
  },
  "include": ["src/cli.ts", "src/numbl-core/**/*"],
  "exclude": ["node_modules", "dist", "dist-cli"]
}
